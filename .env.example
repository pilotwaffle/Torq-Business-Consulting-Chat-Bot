# Copy this file to .env and fill in your key.
# Get an Anthropic API key: https://console.anthropic.com/settings/keys
#
# WARNING: This is a client-side (browser) app, so this key is bundled into the
# shipped JavaScript and is visible to anyone who loads the site. Use it for
# local/personal use only. Do NOT deploy publicly with a live key — put the key
# behind a server-side proxy instead.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
